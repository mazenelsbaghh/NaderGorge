# .NET Backend
ConnectionStrings__DefaultConnection=Host=localhost;Database=nadergorge;Username=postgres;Password=postgres
# Local native Redis default. Docker compose uses redis:6379 internally; run `make docker-volumes` before first Docker start if external volumes are missing.
Redis__ConnectionString=localhost:6379
JwtSettings__Secret=ReplaceThisWithATwentyFourByteSecretForDevelopment12
JwtSettings__Issuer=NaderGorgeAPI
JwtSettings__Audience=NaderGorgeClients
JwtSettings__ExpirationMinutes=60
JwtSettings__RefreshExpirationDays=30
DeviceLimits__MaxDevicesPerStudent=2
