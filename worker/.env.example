# BullMQ Worker
# Local native Redis default. Docker compose uses redis:6379 internally; run `make docker-volumes` before first Docker start if external volumes are missing.
REDIS_URL=redis://localhost:6379
DB_CONNECTION_STRING=Host=localhost;Database=nadergorge;Username=postgres;Password=postgres

# AI Config — Vertex AI is the default. Authentication uses Application Default Credentials.
AI_PRIMARY_PROVIDER=vertex
GOOGLE_CLOUD_PROJECT=CHANGE_ME_IN_LOCAL_ENV
GOOGLE_CLOUD_LOCATION=global
AI_TEMP_GCS_BUCKET=CHANGE_ME_IN_LOCAL_ENV
AI_TEMP_GCS_PREFIX=ai-analysis
AI_TEXT_MODEL=gemini-2.5-flash
AI_IMAGE_MODEL=gemini-3-pro-image-preview
# Optional standard ADC credential file for local/Docker use; prefer workload identity in production.
# Docker host source; Compose mounts this file read-only into the worker.
GOOGLE_APPLICATION_CREDENTIALS_HOST_PATH=./secrets/google-application-credentials.json
# Native execution only. Compose fixes this to the in-container path.
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-application-credentials.json
# Separate Developer API credential used only after explicit Vertex quota exhaustion.
GEMINI_FALLBACK_API_KEY=CHANGE_ME_IN_LOCAL_ENV
# Required only when AI_PRIMARY_PROVIDER=developer for explicit local/rollback compatibility.
# GEMINI_API_KEY=CHANGE_ME_IN_LOCAL_ENV
# Optional: explicitly set ffmpeg path if not in the global PATH environment
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# Webhook secret to hit the .NET API
API_CALLBACK_SECRET=CHANGE_ME_MIN_32_CHARS
AI_CALLBACK_SECRET=CHANGE_ME_MIN_32_CHARS
WORKER_ADMIN_TOKEN=CHANGE_ME_MIN_32_CHARS
SUBTITLE_STORAGE_PATH=.tmp/subtitles
PUBLIC_SUBTITLE_BASE_URL=/subtitles
