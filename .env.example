# =============================================================================
# Massar Platform — Docker Stack Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# Runtime surfaces (Local Development):
#   Landing:   http://localhost:8738   (or http://massar-academy.net:8738)
#   Student:   http://localhost:8739   (or http://app.massar-academy.net:8739)
#   Admin:     http://localhost:8740   (or http://admin.massar-academy.net:8740)
#   Teacher:   http://localhost:8741   (or http://teacher.massar-academy.net:8741)
#   Assistant: http://localhost:8742   (or http://staff.massar-academy.net:8742)
#   Backend:   http://localhost:5245
#
# Production Subdomains:
#   Landing:   massar-academy.net
#   Student:   app.massar-academy.net
#   Admin:     admin.massar-academy.net
#   Teacher:   teacher.massar-academy.net
#   Assistant: staff.massar-academy.net
# =============================================================================

# ─── 1. PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=massar_platform
POSTGRES_HOST=db
POSTGRES_PORT=5432
MASSAR_POSTGRES_PORT=5435

# ─── 2. Redis ───────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
MASSAR_REDIS_PORT=6382

# ─── 3. Separated Runtime Ports ────────────────────────────────────────────
MASSAR_LANDING_PORT=8738
MASSAR_STUDENT_PORT=8739
MASSAR_ADMIN_PORT=8740
MASSAR_BACKEND_PORT=5245
MASSAR_WORKER_PORT=3001

LANDING_PUBLIC_ORIGIN=http://localhost:8738
STUDENT_PUBLIC_ORIGIN=http://localhost:8739
ADMIN_PUBLIC_ORIGIN=http://localhost:8740
TEACHER_PUBLIC_ORIGIN=http://localhost:8741
ASSISTANT_PUBLIC_ORIGIN=http://localhost:8742
NEXT_PUBLIC_APP_DOMAIN=massar-academy.net

# ─── 4. Backend (.NET) ──────────────────────────────────────────────────────
# REQUIRED — Change to a random 32+ character string
JWT_SECRET=change_me_to_a_long_random_secret_string_here_min32chars

JWT_ISSUER=MassarPlatformAPI
JWT_AUDIENCE=MassarPlatformClients
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_DAYS=30

MAX_DEVICES_PER_STUDENT=2

ASPNETCORE_ENVIRONMENT=Docker
ASPNETCORE_URLS=http://+:5245
CORS_ALLOWED_ORIGINS=http://localhost:8738,http://localhost:8739,http://localhost:8740,http://localhost:8741,http://localhost:8742

# Shared secrets for worker/backend callbacks and signed parent reports
API_CALLBACK_SECRET=change_me_to_a_random_callback_secret
AI_CALLBACK_SECRET=change_me_to_a_random_ai_callback_secret
PARENT_REPORT_SIGNING_SECRET=change_me_to_a_random_parent_report_secret

# WhatsApp Evolution API (optional — leave empty if not using WhatsApp features)
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=Massar

# ─── 5. AI Worker (Node.js) ─────────────────────────────────────────────────
# REQUIRED — Get from https://aistudio.google.com/
GEMINI_API_KEY=
WORKER_ADMIN_TOKEN=change_me_to_a_random_worker_admin_token

# Telegram Downloader Integration (Optional - falls back to yt-dlp/Cobalt if not set)
# Create a Telegram App on my.telegram.org to get api_id & api_hash
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Run npm run telegram-login inside worker directory to generate this string session
TELEGRAM_STRING_SESSION=
# The public/famous Telegram downloader bot to send links to
TELEGRAM_DOWNLOADER_BOT=YtbAudioBot

# ─── 6. Frontend (Next.js) ──────────────────────────────────────────────────
# Browser-reachable backend URLs. These must not use Docker-only hostnames.
NEXT_PUBLIC_API_URL=http://localhost:5245/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:5245

# Server-side Docker-internal URLs used by Next.js route handlers/server components.
INTERNAL_API_URL=http://backend:5245/api
INTERNAL_BACKEND_URL=http://backend:5245

# Worker URL is server-side only, used by the Next.js API proxy for AI status.
WORKER_URL=http://worker:3001
