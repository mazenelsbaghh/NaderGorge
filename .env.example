# =============================================================================
# Nader George Platform — Docker Stack Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# Sections:
#   1. PostgreSQL Database
#   2. Redis
#   3. Backend (.NET ASP.NET Core)
#   4. AI Worker (Node.js BullMQ)
#   5. Frontend (Next.js)
# =============================================================================

# ─── 1. PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nadergorge
# Docker service DNS names (used by backend & worker to reach db/redis inside Docker)
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── 2. Redis ───────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── 3. Backend (.NET) ──────────────────────────────────────────────────────
# REQUIRED — Change to a random 32+ character string
JWT_SECRET=change_me_to_a_long_random_secret_string_here_min32chars

JWT_ISSUER=NaderGorgeAPI
JWT_AUDIENCE=NaderGorgeClients
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_DAYS=30

MAX_DEVICES_PER_STUDENT=2

ASPNETCORE_ENVIRONMENT=Docker
ASPNETCORE_URLS=http://+:5245
CORS_ALLOWED_ORIGINS=http://localhost:8738

# Shared secret for worker → backend webhook callbacks
API_CALLBACK_SECRET=change_me_to_a_random_callback_secret

# WhatsApp Evolution API (optional — leave empty if not using WhatsApp features)
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=Nader

# ─── 4. AI Worker (Node.js) ─────────────────────────────────────────────────
# REQUIRED — Get from https://aistudio.google.com/
GEMINI_API_KEY=

# ─── 5. Frontend (Next.js) ──────────────────────────────────────────────────
# These point to the backend via Docker internal DNS (backend:5245)
NEXT_PUBLIC_API_URL=http://backend:5245/api
NEXT_PUBLIC_BACKEND_URL=http://backend:5245
# Worker URL (server-side only — used by Next.js API proxy for AI status)
WORKER_URL=http://worker:3001
